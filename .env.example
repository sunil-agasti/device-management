# ============================================
# TCS Admin Portal - Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# App URL (your machine's VPN IP or localhost)
APP_URL=https://17.x.x.x:3000

# ============================================
# Apple IDMS Authentication
# ============================================
# Set to "true" to enable IDMS SSO (requires registration)
# When "false", falls back to VPN IP-based auth
IDMS_ENABLED=false

# IDMS OAuth2 Configuration
# Register your app at: https://idmsac.apple.com (or contact Identity team)
IDMS_AUTH_URL=https://idmsac.apple.com/IDMSWebAuth/authenticate
IDMS_TOKEN_URL=https://idmsac.apple.com/IDMSWebAuth/token
IDMS_CLIENT_ID=tcs-admin-portal
IDMS_CLIENT_SECRET=your-client-secret-here

# Public client ID (available to browser)
NEXT_PUBLIC_IDMS_CLIENT_ID=tcs-admin-portal

# ============================================
# at.apple.com Setup Instructions
# ============================================
# 1. Go to https://at.apple.com (requires Apple SSO)
# 2. Create redirect: tcs-is-admin-p0rtal -> https://<your-vpn-ip>:3000
# 3. Users visit: https://at.apple.com/tcs-is-admin-p0rtal
# 4. Apple authenticates via IDMS, then redirects to your local server
# 5. Your server picks up the user's system IP for access management
